module qspi_pure_xip ( clk, rst_n, start, addr_in, done, qspi_cs_n, qspi_clk, 
        qspi_io_oe, qspi_io_out, rx_data, qspi_io_in );
  input [31:0] addr_in;
  output [3:0] qspi_io_out;
  output [31:0] rx_data;
  input [3:0] qspi_io_in;
