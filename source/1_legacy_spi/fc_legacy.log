#########################################################################
# ICC2 MCMM Physical Design Script: Legacy SPI Controller
# Run from: source/1_legacy_spi after run_dc.tcl
# Fair-comparison settings match pure XIP and dual-mode scripts.
#########################################################################
set DESIGN_NAME "legacy_spi_controller"
legacy_spi_controller
set TOP_MODULE  "ahb_spi_legacy"
ahb_spi_legacy
if {[info exists ::env(SAED14_PATH)]} {
    set SAED_PATH $::env(SAED14_PATH)
} else {
    set SAED_PATH "/data/synopsys/lib/saed14nm"
}
/data/synopsys/lib/saed14nm
set NETLIST_FILE "outputs/${DESIGN_NAME}_mapped.v"
outputs/legacy_spi_controller_mapped.v
set DDC_FILE     "outputs/${DESIGN_NAME}.ddc"
outputs/legacy_spi_controller.ddc
set SDC_FILE     "outputs/${DESIGN_NAME}.sdc"
outputs/legacy_spi_controller.sdc
set search_path ". $SAED_PATH/lib/stdcell_rvt/db_nldm $SAED_PATH/lib/stdcell_rvt/ndm"
. /data/synopsys/lib/saed14nm/lib/stdcell_rvt/db_nldm /data/synopsys/lib/saed14nm/lib/stdcell_rvt/ndm
set target_library "saed14rvt_tt0p8v25c.db"
saed14rvt_tt0p8v25c.db
set link_library "* $target_library"
* saed14rvt_tt0p8v25c.db
set tech_file        "$SAED_PATH/lib/tech/milkyway/saed14nm_1p9m_mw.tf"
/data/synopsys/lib/saed14nm/lib/tech/milkyway/saed14nm_1p9m_mw.tf
set physical_library "$SAED_PATH/lib/stdcell_rvt/ndm/saed14rvt_frame_timing_ccs.ndm"
/data/synopsys/lib/saed14nm/lib/stdcell_rvt/ndm/saed14rvt_frame_timing_ccs.ndm
set tlup_max "$SAED_PATH/lib/tech/star_rc/max/saed14nm_1p9m_Cmax.tluplus"
/data/synopsys/lib/saed14nm/lib/tech/star_rc/max/saed14nm_1p9m_Cmax.tluplus
set tlup_min "$SAED_PATH/lib/tech/star_rc/min/saed14nm_1p9m_Cmin.tluplus"
/data/synopsys/lib/saed14nm/lib/tech/star_rc/min/saed14nm_1p9m_Cmin.tluplus
close_lib -all
